# E-coomy — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local Docker testing:
#   cp .env.example .env
#
# On Render, set these in:
#   Dashboard → Your Service → Environment → Add Environment Variable
#
# NEVER commit the real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# External MySQL provider options (all have free tiers):
#   • Railway  → https://railway.app
#   • Aiven    → https://aiven.io
#   • PlanetScale (MySQL-compatible) → https://planetscale.com

DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=Base_Client
