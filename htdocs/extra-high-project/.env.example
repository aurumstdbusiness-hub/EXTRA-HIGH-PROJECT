# E-coomy — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local Docker testing:
#   cp .env.example .env
#
# On Render, set these in:
#   Dashboard → Your Service → Environment → Add Environment Variable
#
# NEVER commit the real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A — Railway single URL (takes priority if set) ────────────────────
# Copy the exact value from Railway → MySQL service → Variables → MYSQL_URL
MYSQL_URL=mysql://user:password@host:port/Base_Client

# ── Option B — individual variables (Render, Aiven, or local Docker) ─────────
# Used only if MYSQL_URL is not set
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=Base_Client
