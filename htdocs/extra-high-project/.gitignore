# =============================================================================
#  E-coomy — .gitignore
# =============================================================================

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temp / dev scripts ────────────────────────────────────────────────────────
_write_*.py
_rename_*.py
_fix_*.py
_reorganize*.py
__pycache__/
*.pyc

# ── PHP ───────────────────────────────────────────────────────────────────────
vendor/
composer.lock

# ── Node (if ever added) ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Docker volumes ────────────────────────────────────────────────────────────
db_data/
